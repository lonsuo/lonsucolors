---

---

<output
    id="toast"
    aria-live="polite"
    aria-atomic="true"
    class="pointer-events-none fixed bottom-8 left-1/2 z-50 flex -translate-x-1/2 items-center gap-3 bg-zinc-900 px-6 py-3 text-sm font-bold tracking-wide text-zinc-50 opacity-0 shadow-brutalist transition-opacity duration-150"
>
    <div
        id="toast-color"
        class="h-5 w-5 border-2 border-zinc-50"
        aria-hidden="true"
    >
    </div>
    <span id="toast-text">copied</span>
</output>

<script>
    let toastTimeout: ReturnType<typeof setTimeout> | undefined;

    const toast = document.getElementById("toast");
    const toastText = document.getElementById("toast-text");
    const toastColor = document.getElementById("toast-color");

    function handleCopy(hexString: string | null) {
        if (!hexString || !toast || !toastText || !toastColor) return;

        navigator.clipboard.writeText(hexString).then(() => {
            toastText.textContent = `copied: ${hexString}`;
            toastColor.style.backgroundColor = hexString;

            toast.classList.remove("opacity-0");
            toast.classList.add("opacity-100");

            clearTimeout(toastTimeout);
            toastTimeout = setTimeout(() => {
                toast.classList.remove("opacity-100");
                toast.classList.add("opacity-0");
            }, 1500);
        });
    }

    document.querySelectorAll(".color-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            handleCopy(btn.getAttribute("data-copy"));
        });

        btn.addEventListener("keydown", (e: Event) => {
            const keyboardEvent = e as KeyboardEvent;

            if (keyboardEvent.key === "Enter" || keyboardEvent.key === " ") {
                keyboardEvent.preventDefault();
                handleCopy(btn.getAttribute("data-copy"));
            }
        });
    });
</script>
