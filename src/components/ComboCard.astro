---
interface Props {
    hex1: string;
    hex2: string;
}

const { hex1, hex2 } = Astro.props;
---

<div
    class="flex flex-row border-2 border-zinc-900 bg-zinc-50 shadow-brutalist transition-all hover:translate-x-1 hover:translate-y-1 hover:shadow-none"
>
    <div
        role="button"
        tabindex="0"
        aria-label={`Copy color #${hex1} to clipboard`}
        data-copy={`#${hex1}`}
        class="color-btn relative flex w-1/2 cursor-pointer flex-col border-r-2 border-zinc-900 transition-colors hover:bg-zinc-200 focus:outline-none focus-visible:z-10 focus-visible:ring-4 focus-visible:ring-zinc-900"
    >
        <div
            class="h-28 w-full border-b-2 border-zinc-900"
            style={`background-color: #${hex1};`}
            aria-hidden="true"
        >
        </div>
        <div class="flex w-full items-center justify-center p-4">
            <span class="text-sm font-bold uppercase tracking-wider text-zinc-900" aria-hidden="true">
                #{hex1}
            </span>
        </div>
    </div>

    <div
        role="button"
        tabindex="0"
        aria-label={`Copy color #${hex2} to clipboard`}
        data-copy={`#${hex2}`}
        class="color-btn relative flex w-1/2 cursor-pointer flex-col transition-colors hover:bg-zinc-200 focus:outline-none focus-visible:z-10 focus-visible:ring-4 focus-visible:ring-zinc-900"
    >
        <div
            class="h-28 w-full border-b-2 border-zinc-900"
            style={`background-color: #${hex2};`}
            aria-hidden="true"
        >
        </div>
        <div class="flex w-full items-center justify-center p-4">
            <span class="text-sm font-bold uppercase tracking-wider text-zinc-900" aria-hidden="true">
                #{hex2}
            </span>
        </div>
    </div>
</div>